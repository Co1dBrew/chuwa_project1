{
  // TypeScript configuration for the client application.
  // These options are the standard settings used by Vite + React + TypeScript projects.
  "compilerOptions": {
    // The JavaScript language version the code will be compiled down to.
    "target": "ES2020",
    // Libraries (built-in type definitions) that are available in the code.
    // "DOM" gives us access to browser things like `document` and `window`.
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    // Use the modern ES module system (import / export).
    "module": "ESNext",
    // Let the bundler (Vite) decide how to find modules.
    "moduleResolution": "bundler",
    // Allow importing .json files as modules.
    "resolveJsonModule": true,
    // Every file is treated as a separate module.
    "isolatedModules": true,
    // We do not emit compiled files here; Vite does the building.
    "noEmit": true,
    // How JSX (the HTML-like syntax in React) is compiled.
    "jsx": "react-jsx",
    // Turn on all strict type-checking options. This helps catch mistakes early.
    "strict": true,
    // Skip type-checking of library declaration files to speed things up.
    "skipLibCheck": true,
    // Allow default imports from modules that do not have a default export.
    "esModuleInterop": true,
    // Make sure switch statements do not accidentally fall through.
    "noFallthroughCasesInSwitch": true,
    // Allow importing files using their .ts / .tsx extension.
    "allowImportingTsExtensions": true
  },
  // Only type-check files inside the "src" folder.
  "include": ["src"]
}
